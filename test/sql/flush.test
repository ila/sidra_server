# name: test/sql/flush.test
# description: Test SIDRA flush pipeline (staging → centralized via CMV)
# group: [sql]

require server

# Use file-based DB matching server.config's db_name
load activity_sessions.db

# ============================================================
# Setup: base table + DMV + CMV
# ============================================================

statement ok
CREATE DECENTRALIZED TABLE runs (nickname VARCHAR, city VARCHAR DIMENSION, date DATE DIMENSION, steps INT FACT, hr INT SENSITIVE);

statement ok
CREATE DECENTRALIZED MATERIALIZED VIEW daily_steps_user AS SELECT city, SUM(steps) AS total_steps FROM runs GROUP BY city WINDOW 24 TTL 72 REFRESH 6;

# CMV aggregates from DMV staging — creates sidra_centralized_view_daily_steps
statement ok
CREATE CENTRALIZED MATERIALIZED VIEW daily_steps AS SELECT city, SUM(total_steps) AS total_steps FROM daily_steps_user GROUP BY city REFRESH 12;

# Register fake clients
statement ok
INSERT INTO sidra_clients VALUES (1, now()::TIMESTAMP, now()::TIMESTAMP);

statement ok
INSERT INTO sidra_clients VALUES (2, now()::TIMESTAMP, now()::TIMESTAMP);

statement ok
INSERT INTO sidra_clients VALUES (3, now()::TIMESTAMP, now()::TIMESTAMP);

# Verify tables exist
query I
SELECT COUNT(*) FROM information_schema.tables WHERE table_name = 'sidra_staging_view_daily_steps_user';
----
1

query I
SELECT COUNT(*) FROM information_schema.tables WHERE table_name = 'sidra_centralized_view_daily_steps';
----
1

# ============================================================
# Test 1: Basic flush
# ============================================================

statement ok
INSERT INTO sidra_staging_view_daily_steps_user VALUES ('Berlin', 100, now()::TIMESTAMPTZ, now()::TIMESTAMPTZ, 0, 1, 0);

statement ok
INSERT INTO sidra_staging_view_daily_steps_user VALUES ('Berlin', 200, now()::TIMESTAMPTZ, now()::TIMESTAMPTZ, 0, 2, 0);

statement ok
INSERT INTO sidra_staging_view_daily_steps_user VALUES ('Paris', 150, now()::TIMESTAMPTZ, now()::TIMESTAMPTZ, 0, 3, 0);

query I
SELECT COUNT(*) FROM sidra_staging_view_daily_steps_user;
----
3

statement ok
pragma flush('daily_steps', 'duckdb');

# CMV aggregates by city
query II
SELECT city, total_steps FROM sidra_centralized_view_daily_steps ORDER BY city;
----
Berlin	300
Paris	150

# ============================================================
# Test 2: Flush with min_agg filtering
# ============================================================

statement ok
CREATE DECENTRALIZED MATERIALIZED VIEW agg_src AS SELECT city, SUM(steps) AS total_steps FROM runs GROUP BY city WINDOW 24 TTL 72 REFRESH 6;

statement ok
CREATE CENTRALIZED MATERIALIZED VIEW agg_view AS SELECT city, SUM(total_steps) AS total_steps FROM agg_src GROUP BY city REFRESH 12 MINIMUM AGGREGATION 3;

# Only 2 clients for London (below min_agg=3)
statement ok
INSERT INTO sidra_staging_view_agg_src VALUES ('London', 100, now()::TIMESTAMPTZ, now()::TIMESTAMPTZ, 0, 1, 0);

statement ok
INSERT INTO sidra_staging_view_agg_src VALUES ('London', 200, now()::TIMESTAMPTZ, now()::TIMESTAMPTZ, 0, 2, 0);

statement ok
pragma flush('agg_view', 'duckdb');

# Centralized should be empty (threshold not met)
query I
SELECT COUNT(*) FROM sidra_centralized_view_agg_view;
----
0

# Staging should still have 2 rows
query I
SELECT COUNT(*) FROM sidra_staging_view_agg_src;
----
2

# Add a 3rd client — now meets threshold
statement ok
INSERT INTO sidra_staging_view_agg_src VALUES ('London', 300, now()::TIMESTAMPTZ, now()::TIMESTAMPTZ, 0, 3, 0);

# Reset last_refresh so next flush picks up all rows
statement ok
UPDATE sidra_view_constraints SET last_refresh = '1970-01-01'::TIMESTAMP WHERE view_name = 'agg_src';

statement ok
pragma flush('agg_view', 'duckdb');

# Centralized should have London (aggregated: 100+200+300 = 600)
query II
SELECT city, total_steps FROM sidra_centralized_view_agg_view;
----
London	600

# ============================================================
# Test 3: Expired windows (TTL filtering)
# ============================================================

# Set current window to 5: expired = 5 - 72/24 = 2
statement ok
UPDATE sidra_current_window SET sidra_window = 5 WHERE view_name = 'sidra_staging_view_daily_steps_user';

statement ok
DELETE FROM sidra_staging_view_daily_steps_user;

statement ok
DELETE FROM sidra_centralized_view_daily_steps;

# Window 1 (expired: 1 <= 2), window 3 (valid), window 5 (valid)
statement ok
INSERT INTO sidra_staging_view_daily_steps_user VALUES ('Rome', 50, now()::TIMESTAMPTZ, now()::TIMESTAMPTZ, 1, 10, 0);

statement ok
INSERT INTO sidra_staging_view_daily_steps_user VALUES ('Rome', 100, now()::TIMESTAMPTZ, now()::TIMESTAMPTZ, 3, 11, 0);

statement ok
INSERT INTO sidra_staging_view_daily_steps_user VALUES ('Rome', 200, now()::TIMESTAMPTZ, now()::TIMESTAMPTZ, 5, 12, 0);

statement ok
pragma flush('daily_steps', 'duckdb');

# Valid windows each get their own row; window 1 excluded by TTL
query III
SELECT city, total_steps, sidra_window FROM sidra_centralized_view_daily_steps WHERE city = 'Rome' ORDER BY sidra_window;
----
Rome	100	3
Rome	200	5

# ============================================================
# Test 4: Empty staging (no data to flush)
# ============================================================

statement ok
DELETE FROM sidra_staging_view_daily_steps_user;

statement ok
DELETE FROM sidra_centralized_view_daily_steps;

statement ok
pragma flush('daily_steps', 'duckdb');

query I
SELECT COUNT(*) FROM sidra_centralized_view_daily_steps;
----
0

# ============================================================
# Test 5: Flush non-existent view — should error
# ============================================================

statement error
pragma flush('nonexistent_view', 'duckdb');
----
not found

# ============================================================
# Test 6: Invalid database type — should error
# ============================================================

statement error
pragma flush('daily_steps', 'mysql');
----
Invalid database type

# ============================================================
# Test 7: CMV joining two DMVs
# ============================================================

statement ok
CREATE DECENTRALIZED TABLE calories_log (city VARCHAR DIMENSION, cals INT FACT);

statement ok
CREATE DECENTRALIZED MATERIALIZED VIEW daily_cals AS SELECT city, SUM(cals) AS total_cals FROM calories_log GROUP BY city WINDOW 24 TTL 72 REFRESH 6;

statement ok
CREATE CENTRALIZED MATERIALIZED VIEW combined AS SELECT a.city, SUM(a.total_steps) AS total_steps, SUM(b.total_cals) AS total_cals FROM daily_steps_user a JOIN daily_cals b ON a.city = b.city GROUP BY a.city REFRESH 12;

# Clean staging
statement ok
DELETE FROM sidra_staging_view_daily_steps_user;

statement ok
UPDATE sidra_current_window SET sidra_window = 0 WHERE view_name = 'sidra_staging_view_daily_steps_user';

statement ok
INSERT INTO sidra_staging_view_daily_steps_user VALUES ('Berlin', 100, now()::TIMESTAMPTZ, now()::TIMESTAMPTZ, 0, 1, 0);

statement ok
INSERT INTO sidra_staging_view_daily_steps_user VALUES ('Paris', 200, now()::TIMESTAMPTZ, now()::TIMESTAMPTZ, 0, 2, 0);

statement ok
INSERT INTO sidra_staging_view_daily_cals VALUES ('Berlin', 500, now()::TIMESTAMPTZ, now()::TIMESTAMPTZ, 0, 1, 0);

statement ok
INSERT INTO sidra_staging_view_daily_cals VALUES ('Paris', 700, now()::TIMESTAMPTZ, now()::TIMESTAMPTZ, 0, 2, 0);

statement ok
pragma flush('combined', 'duckdb');

query III
SELECT city, total_steps, total_cals FROM sidra_centralized_view_combined ORDER BY city;
----
Berlin	100	500
Paris	200	700

# ============================================================
# Test 8: Incremental flush — arrival filter prevents re-processing (Eq. 8)
# ============================================================

# Clean slate
statement ok
DELETE FROM sidra_staging_view_daily_steps_user;

statement ok
DELETE FROM sidra_centralized_view_daily_steps;

statement ok
UPDATE sidra_view_constraints SET last_refresh = '1970-01-01'::TIMESTAMP WHERE view_name = 'daily_steps_user';

statement ok
UPDATE sidra_current_window SET sidra_window = 0 WHERE view_name = 'sidra_staging_view_daily_steps_user';

# Batch 1: insert and flush
statement ok
INSERT INTO sidra_staging_view_daily_steps_user VALUES ('Tokyo', 500, now()::TIMESTAMPTZ, now()::TIMESTAMPTZ, 0, 1, 0);

statement ok
pragma flush('daily_steps', 'duckdb');

query II
SELECT city, total_steps FROM sidra_centralized_view_daily_steps WHERE city = 'Tokyo';
----
Tokyo	500

# Batch 2: insert more (arrival > last_refresh ensures only new rows processed)
statement ok
INSERT INTO sidra_staging_view_daily_steps_user VALUES ('Tokyo', 600, now()::TIMESTAMPTZ, now()::TIMESTAMPTZ, 0, 2, 0);

statement ok
pragma flush('daily_steps', 'duckdb');

# MERGE adds the delta (600) to existing (500) = 1100
query II
SELECT city, total_steps FROM sidra_centralized_view_daily_steps WHERE city = 'Tokyo';
----
Tokyo	1100

# ============================================================
# Test 9: Per-window grouping — each window gets its own row
# ============================================================

statement ok
DELETE FROM sidra_staging_view_daily_steps_user;

statement ok
DELETE FROM sidra_centralized_view_daily_steps;

statement ok
UPDATE sidra_view_constraints SET last_refresh = '1970-01-01'::TIMESTAMP WHERE view_name = 'daily_steps_user';

# Data across 3 windows
statement ok
INSERT INTO sidra_staging_view_daily_steps_user VALUES ('Berlin', 100, now()::TIMESTAMPTZ, now()::TIMESTAMPTZ, 0, 1, 0);

statement ok
INSERT INTO sidra_staging_view_daily_steps_user VALUES ('Berlin', 200, now()::TIMESTAMPTZ, now()::TIMESTAMPTZ, 1, 2, 0);

statement ok
INSERT INTO sidra_staging_view_daily_steps_user VALUES ('Berlin', 300, now()::TIMESTAMPTZ, now()::TIMESTAMPTZ, 2, 3, 0);

statement ok
pragma flush('daily_steps', 'duckdb');

# 3 separate rows — one per window
query III
SELECT city, total_steps, sidra_window FROM sidra_centralized_view_daily_steps ORDER BY sidra_window;
----
Berlin	100	0
Berlin	200	1
Berlin	300	2

# ============================================================
# Test 10: Multiple clients same city/window — aggregated
# ============================================================

statement ok
DELETE FROM sidra_staging_view_daily_steps_user;

statement ok
DELETE FROM sidra_centralized_view_daily_steps;

statement ok
UPDATE sidra_view_constraints SET last_refresh = '1970-01-01'::TIMESTAMP WHERE view_name = 'daily_steps_user';

statement ok
INSERT INTO sidra_staging_view_daily_steps_user VALUES ('NYC', 100, now()::TIMESTAMPTZ, now()::TIMESTAMPTZ, 0, 10, 0);

statement ok
INSERT INTO sidra_staging_view_daily_steps_user VALUES ('NYC', 200, now()::TIMESTAMPTZ, now()::TIMESTAMPTZ, 0, 11, 0);

statement ok
INSERT INTO sidra_staging_view_daily_steps_user VALUES ('NYC', 300, now()::TIMESTAMPTZ, now()::TIMESTAMPTZ, 0, 12, 0);

statement ok
pragma flush('daily_steps', 'duckdb');

# All 3 clients aggregated into 1 row for (NYC, window 0)
query III
SELECT city, total_steps, sidra_window FROM sidra_centralized_view_daily_steps;
----
NYC	600	0

# ============================================================
# Test 11: Flush DMV directly — should error
# ============================================================

statement error
pragma flush('daily_steps_user', 'duckdb');
----
No centralized MV defined

# ============================================================
# Test 12: TTL + min_agg combined (Eq. 12)
# ============================================================

statement ok
DELETE FROM sidra_staging_view_agg_src;

statement ok
DELETE FROM sidra_centralized_view_agg_view;

statement ok
UPDATE sidra_view_constraints SET last_refresh = '1970-01-01'::TIMESTAMP WHERE view_name = 'agg_src';

statement ok
UPDATE sidra_current_window SET sidra_window = 5 WHERE view_name = 'sidra_staging_view_agg_src';

# Window 1 (expired: 1 <= 2), 3 clients — meets min_agg but expired
statement ok
INSERT INTO sidra_staging_view_agg_src VALUES ('Madrid', 100, now()::TIMESTAMPTZ, now()::TIMESTAMPTZ, 1, 1, 0);

statement ok
INSERT INTO sidra_staging_view_agg_src VALUES ('Madrid', 200, now()::TIMESTAMPTZ, now()::TIMESTAMPTZ, 1, 2, 0);

statement ok
INSERT INTO sidra_staging_view_agg_src VALUES ('Madrid', 300, now()::TIMESTAMPTZ, now()::TIMESTAMPTZ, 1, 3, 0);

# Window 4 (valid: 4 > 2), 3 clients — meets min_agg and valid
statement ok
INSERT INTO sidra_staging_view_agg_src VALUES ('Madrid', 400, now()::TIMESTAMPTZ, now()::TIMESTAMPTZ, 4, 4, 0);

statement ok
INSERT INTO sidra_staging_view_agg_src VALUES ('Madrid', 500, now()::TIMESTAMPTZ, now()::TIMESTAMPTZ, 4, 5, 0);

statement ok
INSERT INTO sidra_staging_view_agg_src VALUES ('Madrid', 600, now()::TIMESTAMPTZ, now()::TIMESTAMPTZ, 4, 6, 0);

# Window 4 (valid), 2 clients for Rome — below min_agg
statement ok
INSERT INTO sidra_staging_view_agg_src VALUES ('Rome', 50, now()::TIMESTAMPTZ, now()::TIMESTAMPTZ, 4, 7, 0);

statement ok
INSERT INTO sidra_staging_view_agg_src VALUES ('Rome', 60, now()::TIMESTAMPTZ, now()::TIMESTAMPTZ, 4, 8, 0);

statement ok
pragma flush('agg_view', 'duckdb');

# Only Madrid window 4 should pass (valid window + meets min_agg)
# Madrid window 1: expired (filtered by TTL)
# Rome window 4: only 2 clients (below min_agg=3)
query III
SELECT city, total_steps, sidra_window FROM sidra_centralized_view_agg_view ORDER BY city;
----
Madrid	1500	4

# ============================================================
# Test 13: Staging data persists after flush (not deleted)
# ============================================================

query I
SELECT COUNT(*) FROM sidra_staging_view_agg_src;
----
8

# ============================================================
# Test 14: Metric columns exist and have default values
# ============================================================

