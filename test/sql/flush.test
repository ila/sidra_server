query I
SELECT COUNT(*) FROM sidra_centralized_view_daily_steps WHERE city = 'NYC' AND completeness IS NOT NULL;
----
1

query I
SELECT COUNT(*) FROM sidra_centralized_view_daily_steps WHERE city = 'NYC' AND buffer_size IS NOT NULL;
----
1

# ============================================================
# Test 15: Flush with multi-column GROUP BY DMV
# ============================================================

statement ok
CREATE DECENTRALIZED MATERIALIZED VIEW city_date AS SELECT city, date, SUM(steps) AS total_steps FROM runs GROUP BY city, date WINDOW 24 TTL 72 REFRESH 6;

statement ok
CREATE CENTRALIZED MATERIALIZED VIEW city_date_totals AS SELECT city, date, SUM(total_steps) AS total_steps FROM city_date GROUP BY city, date REFRESH 12;

statement ok
INSERT INTO sidra_staging_view_city_date VALUES ('Berlin', '2024-01-01', 500, now()::TIMESTAMPTZ, now()::TIMESTAMPTZ, 0, 50, 0);

statement ok
INSERT INTO sidra_staging_view_city_date VALUES ('Berlin', '2024-01-02', 600, now()::TIMESTAMPTZ, now()::TIMESTAMPTZ, 0, 51, 0);

statement ok
INSERT INTO sidra_staging_view_city_date VALUES ('Paris', '2024-01-01', 700, now()::TIMESTAMPTZ, now()::TIMESTAMPTZ, 0, 52, 0);

statement ok
pragma flush('city_date_totals', 'duckdb');

query III
SELECT city, date, total_steps FROM sidra_centralized_view_city_date_totals ORDER BY city, date;
----
Berlin	2024-01-01	500
Berlin	2024-01-02	600
Paris	2024-01-01	700
