# name: test/sql/parser.test
# description: Test SIDRA parser extension
# group: [sql]

require server

# ============================================================
# Scope detection
# ============================================================

# Non-materialized views are not allowed
statement error
CREATE DECENTRALIZED VIEW test AS SELECT 1;
----
Views should be materialized

# Replicated must be a materialized view, not a table
statement error
CREATE REPLICATED TABLE test (id INT);
----
Replicated tables must be materialized views

# Multiple scopes rejected by DuckDB parser before reaching extension
statement error
CREATE CENTRALIZED DECENTRALIZED TABLE test (id INT);
----
syntax error

# ============================================================
# View constraints — decentralized
# ============================================================

# Missing WINDOW
statement error
CREATE DECENTRALIZED MATERIALIZED VIEW test AS SELECT 1 FROM t TTL 72 REFRESH 6;
----
WINDOW is a required field

# Missing TTL
statement error
CREATE DECENTRALIZED MATERIALIZED VIEW test AS SELECT 1 FROM t WINDOW 24 REFRESH 6;
----
TTL is a required field

# Missing REFRESH
statement error
CREATE DECENTRALIZED MATERIALIZED VIEW test AS SELECT 1 FROM t WINDOW 24 TTL 72;
----
REFRESH is a required field

# TTL < WINDOW
statement error
CREATE DECENTRALIZED MATERIALIZED VIEW test AS SELECT 1 FROM t WINDOW 24 TTL 12 REFRESH 6;
----
TTL must be greater than or equal to WINDOW

# MINIMUM AGGREGATION not allowed for decentralized
statement error
CREATE DECENTRALIZED MATERIALIZED VIEW test AS SELECT 1 FROM t WINDOW 24 TTL 72 REFRESH 6 MINIMUM AGGREGATION 10;
----
MINIMUM AGGREGATION is not allowed for decentralized tables

# ============================================================
# View constraints — centralized
# ============================================================

# WINDOW not allowed for centralized
statement error
CREATE CENTRALIZED MATERIALIZED VIEW test AS SELECT 1 FROM t WINDOW 24 REFRESH 6;
----
WINDOW is not allowed for centralized or replicated tables

# TTL not allowed for centralized
statement error
CREATE CENTRALIZED MATERIALIZED VIEW test AS SELECT 1 FROM t TTL 72 REFRESH 6;
----
TTL is not allowed for centralized or replicated tables

# Missing REFRESH for centralized
statement error
CREATE CENTRALIZED MATERIALIZED VIEW test AS SELECT 1 FROM t;
----
REFRESH is a required field

# ============================================================
# View constraints — replicated
# ============================================================

# WINDOW not allowed for replicated
statement error
CREATE REPLICATED MATERIALIZED VIEW test AS SELECT 1 FROM t WINDOW 24 REFRESH 6;
----
WINDOW is not allowed for centralized or replicated tables

# TTL not allowed for replicated
statement error
CREATE REPLICATED MATERIALIZED VIEW test AS SELECT 1 FROM t TTL 72 REFRESH 6;
----
TTL is not allowed for centralized or replicated tables

# Missing REFRESH for replicated
statement error
CREATE REPLICATED MATERIALIZED VIEW test AS SELECT 1 FROM t;
----
REFRESH is a required field

# ============================================================
# Edge cases — comments and whitespace
# ============================================================

# SQL with line comments
statement error
CREATE DECENTRALIZED MATERIALIZED VIEW test -- a comment
AS SELECT 1 FROM t WINDOW 24 TTL 72;
----
REFRESH is a required field

# SQL with block comments
statement error
CREATE DECENTRALIZED MATERIALIZED VIEW test /* block comment */ AS SELECT 1 FROM t WINDOW 24 TTL 72;
----
REFRESH is a required field

# Extra whitespace between keywords
statement error
CREATE   DECENTRALIZED   MATERIALIZED   VIEW   test AS SELECT 1 FROM t WINDOW 24 TTL 72;
----
REFRESH is a required field

# ============================================================
# Reserved name validation
# ============================================================

# View name starting with sidra_staging_view_ is rejected
statement error
CREATE CENTRALIZED MATERIALIZED VIEW sidra_staging_view_test AS SELECT 1 FROM t REFRESH 6;
----
Views cannot start with sidra_staging_view_

# ============================================================
# Complex view constraint combinations
# ============================================================

# WINDOW == TTL is allowed
statement error
CREATE DECENTRALIZED MATERIALIZED VIEW test AS SELECT 1 FROM t WINDOW 24 TTL 24 REFRESH 6;
----
Error

# Centralized with MINIMUM AGGREGATION is valid syntax (validation error from missing table)
statement error
CREATE CENTRALIZED MATERIALIZED VIEW test AS SELECT 1 FROM t REFRESH 12 MINIMUM AGGREGATION 15;
----
Error

# ============================================================
# Case insensitivity
# ============================================================

# Lowercase scope keywords
statement error
create decentralized materialized view test as select 1 from t window 24 ttl 72;
----
REFRESH is a required field

# Mixed case
statement error
Create Decentralized Materialized View test AS Select 1 From t Window 24 Ttl 72;
----
REFRESH is a required field

# ============================================================
# Valid table creations
# ============================================================

# Centralized table (no constraints needed)
statement ok
CREATE CENTRALIZED TABLE region (code VARCHAR PRIMARY KEY, name VARCHAR);

# Table with all three annotation types
statement ok
CREATE DECENTRALIZED TABLE full_annot (secret INT SENSITIVE, measure DECIMAL FACT, category VARCHAR DIMENSION);

# Table with multiple FACT columns
statement ok
CREATE DECENTRALIZED TABLE multi_fact (id INT SENSITIVE, val INT FACT, city VARCHAR DIMENSION, x INT FACT);
